{
  "name": "sp-rest-explorer-backend",
  "version": "2.0.0",
  "description": "Azure Functions v4 backend for SP REST API Explorer",
  "main": "dist/src/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "deploy": "npm run clean && npm run build && func azure functionapp publish sp-rest-explorer-new --dotnet-version 8.0",
    "start": "npm run build && func start",
    "lint": "eslint src/",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@azure/functions": "^4.11.0",
    "@azure/msal-node": "^2.16.0",
    "@azure/storage-blob": "^12.31.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "lz-string": "^1.5.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/lz-string": "^1.3.34",
    "@types/node": "^20.0.0",
    "@types/xml2js": "^0.4.14",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18"
  }
}

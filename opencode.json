{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "perplexity": {
            "command": [
                "npx",
                "-y",
                "@perplexity-ai/mcp-server"
            ],
            "type": "local",
            "enabled": true,
            "environment": {
                "PERPLEXITY_API_KEY": "{env:PERPLEXITY_API_KEY}"
            }
        },
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "headers": {
                "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
            },
            "enabled": true
        },
        "chrome-devtools": {
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@latest",
                "--autoConnect"
            ],
            "type": "local"
        }
    }
}